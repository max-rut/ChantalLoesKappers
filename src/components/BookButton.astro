---
import site from '../data/site.json';

interface Props {
  label?: string;
  variant?: 'solid' | 'outline';
  size?: 'md' | 'lg';
}

const { label = site.boekKnopLabel, variant = 'solid', size = 'md' } = Astro.props;
const cls = ['btn', variant === 'outline' ? 'btn-outline' : '', size === 'lg' ? 'btn-lg' : '']
  .filter(Boolean)
  .join(' ');
---

<a href={site.boekingUrl} class={cls} target="_blank" rel="noopener">
  {label}
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M7 17L17 7" />
    <path d="M7 7h10v10" />
  </svg>
</a>

<style>
  .btn-lg {
    padding: 1.05rem 2.25rem;
    font-size: 1.05rem;
  }

  a.btn svg {
    transition: transform 0.15s ease;
  }

  a.btn:hover svg {
    transform: translate(2px, -2px);
  }
</style>
