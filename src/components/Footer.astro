---
import { salonName, address, phones, email, bookingUrl, socials } from '../data/contact';
import { openingHours } from '../data/hours';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <h3 class="footer-heading">{salonName}</h3>
      <address>
        {address.street}<br />
        {address.postalCode} {address.city}
      </address>
      <ul class="footer-contact">
        {
          phones.map((p) => (
            <li>
              <span class="muted">{p.label}</span>{' '}
              <a href={`tel:${p.tel}`}>{p.number}</a>
            </li>
          ))
        }
        <li>
          <a href={`mailto:${email}`}>{email}</a>
        </li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Openingstijden</h3>
      <ul class="footer-hours">
        {
          openingHours.map((h) => (
            <li class={h.closed ? 'closed' : ''}>
              <span>{h.day}</span>
              <span>{h.hours}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Afspraak</h3>
      <p class="muted">
        Maak eenvoudig online een afspraak via ons afsprakensysteem.
      </p>
      <a href={bookingUrl} class="btn" target="_blank" rel="noopener">Afspraak maken</a>

      {
        socials.length > 0 && (
          <ul class="footer-socials">
            {socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} {salonName}. Alle rechten voorbehouden.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0 var(--space-md);
    margin-top: var(--space-xl);
    color: var(--color-text);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    margin-bottom: var(--space-sm);
  }

  address {
    font-style: normal;
    margin-bottom: var(--space-sm);
  }

  .footer-contact,
  .footer-hours,
  .footer-socials {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-contact li {
    margin-bottom: 0.35rem;
  }

  .footer-hours li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.35rem 0;
    border-bottom: 1px dashed var(--color-border);
  }

  .footer-hours li.closed {
    color: var(--color-text-muted);
  }

  .footer-hours li:last-child {
    border-bottom: 0;
  }

  .footer-socials {
    margin-top: var(--space-sm);
    display: flex;
    gap: var(--space-sm);
  }

  .muted {
    color: var(--color-text-muted);
  }

  .footer-bottom {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
