---
import site from '../data/site.json';
import contact from '../data/contact.json';
import hours from '../data/hours.json';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <h3 class="footer-heading">{site.salonNaam}</h3>
      <address>
        {contact.adres.straat}<br />
        {contact.adres.postcode} {contact.adres.plaats}
      </address>
      <ul class="footer-contact">
        {
          contact.telefoons.map((p) => (
            <li>
              <span class="muted">{p.label}</span>{' '}
              <a href={`tel:${p.tel}`}>{p.weergave}</a>
            </li>
          ))
        }
        <li>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
        </li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">{site.footer.openingstijdenTitel}</h3>
      <ul class="footer-hours">
        {
          hours.dagen.map((h) => (
            <li class={h.gesloten ? 'closed' : ''}>
              <span>{h.dag}</span>
              <span>{h.tijden}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">{site.footer.afspraakTitel}</h3>
      <p class="muted">
        {site.footer.afspraakTekst}
      </p>
      <a href={site.boekingUrl} class="btn" target="_blank" rel="noopener">{site.boekKnopLabel}</a>

      {
        contact.socials.length > 0 && (
          <ul class="footer-socials">
            {contact.socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} {site.salonNaam}. {site.footer.copyrightZin}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) 0 var(--space-md);
    margin-top: var(--space-xl);
    color: var(--color-text);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    margin-bottom: var(--space-sm);
  }

  address {
    font-style: normal;
    margin-bottom: var(--space-sm);
  }

  .footer-contact,
  .footer-hours,
  .footer-socials {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-contact li {
    margin-bottom: 0.35rem;
  }

  .footer-hours li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.35rem 0;
    border-bottom: 1px dashed var(--color-border);
  }

  .footer-hours li.closed {
    color: var(--color-text-muted);
  }

  .footer-hours li:last-child {
    border-bottom: 0;
  }

  .footer-socials {
    margin-top: var(--space-sm);
    display: flex;
    gap: var(--space-sm);
  }

  .muted {
    color: var(--color-text-muted);
  }

  .footer-bottom {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
