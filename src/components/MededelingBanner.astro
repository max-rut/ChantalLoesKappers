---
import mededeling from '../data/mededeling.json';
---

{
  mededeling.zichtbaar && (
    <aside class="banner" role="note" aria-label="Mededeling">
      <div class="container banner-inner">
        <svg
          class="banner-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="12" />
          <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
        <div>
          {mededeling.titel && <strong>{mededeling.titel}</strong>}
          <span class="body">{mededeling.tekst}</span>
        </div>
      </div>
    </aside>
  )
}

<style>
  .banner {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .banner-inner {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
    padding: 0.85rem var(--space-md);
  }

  .banner-icon {
    flex-shrink: 0;
    color: var(--color-accent-dark);
    margin-top: 2px;
  }

  .banner strong {
    margin-right: 0.5rem;
  }

  .banner .body {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .banner-inner {
      font-size: 0.9rem;
    }
  }
</style>
