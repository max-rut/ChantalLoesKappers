---
import hours from '../data/hours.json';

interface Props {
  showNote?: boolean;
  compact?: boolean;
}

const { showNote = true, compact = false } = Astro.props;
---

<div class={`hours ${compact ? 'compact' : ''}`}>
  <ul>
    {
      hours.dagen.map((h) => (
        <li class={h.gesloten ? 'closed' : ''}>
          <span class="day">{h.dag}</span>
          <span class="time">{h.tijden}</span>
        </li>
      ))
    }
  </ul>
  {showNote && hours.notitie && <p class="note">{hours.notitie}</p>}
</div>

<style>
  .hours ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hours li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hours li:last-child {
    border-bottom: 0;
  }

  .hours li.closed {
    color: var(--color-text-muted);
  }

  .hours .day {
    font-weight: 500;
  }

  .hours .time {
    font-variant-numeric: tabular-nums;
  }

  .hours.compact li {
    padding: 0.4rem 0;
    font-size: 0.95rem;
  }

  .note {
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
