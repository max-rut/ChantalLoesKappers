---
import { openingHours, hoursNote } from '../data/hours';

interface Props {
  showNote?: boolean;
  compact?: boolean;
}

const { showNote = true, compact = false } = Astro.props;
---

<div class={`hours ${compact ? 'compact' : ''}`}>
  <ul>
    {
      openingHours.map((h) => (
        <li class={h.closed ? 'closed' : ''}>
          <span class="day">{h.day}</span>
          <span class="time">{h.hours}</span>
        </li>
      ))
    }
  </ul>
  {showNote && hoursNote && <p class="note">{hoursNote}</p>}
</div>

<style>
  .hours ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hours li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hours li:last-child {
    border-bottom: 0;
  }

  .hours li.closed {
    color: var(--color-text-muted);
  }

  .hours .day {
    font-weight: 500;
  }

  .hours .time {
    font-variant-numeric: tabular-nums;
  }

  .hours.compact li {
    padding: 0.4rem 0;
    font-size: 0.95rem;
  }

  .note {
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
