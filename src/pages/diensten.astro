---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceTable from '../components/ServiceTable.astro';
import BookButton from '../components/BookButton.astro';
import { services, priceDisclaimer } from '../data/services';
---

<BaseLayout
  title="Diensten en prijzen"
  description="Volledig overzicht van behandelingen en prijzen bij Chantal & Loes Kappers in Heiloo: knippen, kleuren en permanenten."
>
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">Onze diensten</span>
      <h1>Diensten en prijzen</h1>
      <p class="lead">
        Hieronder vind je een overzicht van onze behandelingen. Vragen of een
        persoonlijk advies? Bel of mail ons gerust.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {services.map((cat) => <ServiceTable category={cat} />)}
      </div>

      <p class="disclaimer">{priceDisclaimer}</p>

      <div class="cta-row">
        <BookButton size="lg" />
        <a href={`${import.meta.env.BASE_URL}contact`} class="btn btn-outline">
          Neem contact op
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-lg) 0 var(--space-md);
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .disclaimer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: var(--space-md) 0 var(--space-lg);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-row {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
</style>
