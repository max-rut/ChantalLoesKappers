---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceTable from '../components/ServiceTable.astro';
import BookButton from '../components/BookButton.astro';
import diensten from '../data/diensten.json';
import dienstenServices from '../data/diensten-services.json';
---

<BaseLayout title={diensten.meta.titel} description={diensten.meta.beschrijving}>
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">{diensten.header.eyebrow}</span>
      <h1>{diensten.header.titel}</h1>
      <p class="lead">{diensten.header.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {dienstenServices.categorieen.map((cat) => <ServiceTable categorie={cat} />)}
      </div>

      <p class="disclaimer">{dienstenServices.prijsDisclaimer}</p>

      <div class="cta-row">
        <BookButton size="lg" />
        <a href={`${import.meta.env.BASE_URL}contact`} class="btn btn-outline">
          {diensten.tweedeKnopLabel}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-lg) 0 var(--space-md);
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .disclaimer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: var(--space-md) 0 var(--space-lg);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-row {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
</style>
