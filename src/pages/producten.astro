---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import BookButton from '../components/BookButton.astro';
import producten from '../data/producten.json';
import productenLijst from '../data/producten-lijst.json';
---

<BaseLayout title={producten.meta.titel} description={producten.meta.beschrijving}>
  <section class="page-header">
    <div class="container">
      <span class="eyebrow">{producten.header.eyebrow}</span>
      <h1>{producten.header.titel}</h1>
      <p class="lead">{producten.header.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="products-grid">
        {productenLijst.producten.map((p) => <ProductCard product={p} />)}
      </div>

      <div class="info-box">
        <h2>{producten.infoBox.titel}</h2>
        <p>{producten.infoBox.tekst}</p>
        <BookButton />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-lg) 0 var(--space-md);
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
  }

  .lead {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .info-box {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .info-box h2 {
    margin-top: 0;
  }

  .info-box p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
</style>
